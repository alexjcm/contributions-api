{
  "name": "dcm-api",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wrangler --config wrangler.dev.jsonc dev src/index.ts --local",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "types:wrangler": "wrangler --config wrangler.dev.jsonc types",
    "d1:generate": "drizzle-kit generate --config drizzle.config.ts",
    "d1:check": "drizzle-kit check --config drizzle.config.ts",
    "d1:migrate:local": "wrangler --config wrangler.dev.jsonc d1 migrations apply DCM_DB_BINDING --local",
    "d1:reset:local": "./tools/local/d1/reset.sh",
    "d1:seed:local": "./tools/local/d1/seed.sh",
    "d1:bootstrap:local": "npm run d1:reset:local && npm run d1:seed:local",
    "d1:snapshot:local": "./tools/local/d1/snapshot.sh",
    "d1:restore:local": "./tools/local/d1/restore.sh",
    "tool:d1:inspect:local": "./tools/local/d1/inspect.sh"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    }
  }
}
